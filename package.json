{
  "name": "ebisu",
  "displayName": "Ebisu",
  "version": "0.0.1",
  "description": "Ebisu surfaces openings directly from Greenhouse, Lever, Ashby, and other ATS platforms so you can discover fresh roles earlier and stay organized as you search.",
  "private": true,
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "typecheck": "tsc --noEmit",
    "test:ui": "pnpm build && playwright test"
  },
  "dependencies": {
    "@fontsource/public-sans": "latest",
    "@plasmohq/storage": "latest",
    "@radix-ui/react-checkbox": "latest",
    "@radix-ui/react-label": "latest",
    "@radix-ui/react-slot": "latest",
    "class-variance-authority": "latest",
    "clsx": "latest",
    "lucide-react": "latest",
    "plasmo": "latest",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "latest"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/chrome": "latest",
    "@types/node": "latest",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "latest",
    "postcss": "latest",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.0"
  },
  "manifest": {
    "permissions": [
      "tabs",
      "storage"
    ],
    "host_permissions": [
      "https://www.google.com/*",
      "https://greenhouse.io/*",
      "https://*.greenhouse.io/*",
      "https://jobs.lever.co/*",
      "https://ashbyhq.com/*",
      "https://*.ashbyhq.com/*",
      "https://myworkdayjobs.com/*",
      "https://*.myworkdayjobs.com/*"
    ]
  }
}
